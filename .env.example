# 支付宝应用 APPID
ALIPAY_APP_ID=

# 支付宝应用私钥，必须只放在服务端环境变量中，不要暴露到前端。
# 支持一行格式，也支持包含 \n 的 PEM 格式。
ALIPAY_APP_PRIVATE_KEY=

# 支付宝公钥：用于验签支付宝异步通知和查询结果。
# 注意：这里需要填写“支付宝公钥”，不是商户自己的“应用公钥”。
ALIPAY_PUBLIC_KEY=

# 商户应用公钥，仅用于记录和核对，可在支付宝开放平台后台配置。
ALIPAY_APP_PUBLIC_KEY=

# 支付宝异步通知地址，必须是公网 HTTPS 地址。
# 例：https://你的域名/api/alipay/notify
ALIPAY_NOTIFY_URL=

# 正式环境：https://openapi.alipay.com/gateway.do
# 沙箱环境：https://openapi-sandbox.dl.alipaydev.com/gateway.do
ALIPAY_GATEWAY=https://openapi.alipay.com/gateway.do
